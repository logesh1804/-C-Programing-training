#include <stdio.h>

int countOccurrence(int arr[], int n, int key)
{
    int count = 0;

    for(int i = 0; i < n; i++)
    {
        if(arr[i] == key)
        {
            count++;
        }
    }

    return count;
}

int main()
{
    int n, key;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    int arr[n];

    printf("Enter array elements:\n");
    for(int i=0;i<n;i++)
    {
        scanf("%d",&arr[i]);
    }

    printf("Enter element to search: ");
    scanf("%d",&key);

    int result = countOccurrence(arr,n,key);

    printf("Occurrence = %d\n",result);

    return 0;
}
