#include <stdio.h>

int reverseBits(int n)
{
    int result = 0;

    for(int i=0;i<32;i++)
    {
        result = (result << 1) | (n & 1);
        n = n >> 1;
    }

    return result;
}

int main()
{
    int n;

    printf("Enter number: ");
    scanf("%d",&n);

    int reversed = reverseBits(n);

    printf("Reversed bit number = %d\n",reversed);
}
